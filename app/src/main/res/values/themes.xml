<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Artistico" parent="Theme.Material3.Light.NoActionBar">
        <!-- Color scheme -->
        <item name="colorPrimary">@color/brand_maroon</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/brand_rose_chip</item>
        <item name="colorOnPrimaryContainer">@color/brand_maroon</item>

        <item name="colorSecondary">@color/brand_maroon_soft</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorTertiary">@color/brand_maroon_soft</item>
        <item name="colorOnTertiary">@color/white</item>

        <item name="android:colorBackground">@color/brand_pink_bg</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <!-- Must be set explicitly: the Material 3 parent does not derive
             windowBackground from colorBackground, so without this line the
             FragmentManager's brief cross-fade during tab switches lets the
             default (black/white) window colour flash through. -->
        <item name="android:windowBackground">@color/brand_pink_bg</item>

        <item name="colorSurface">@color/brand_pink_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/brand_pink_surface</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/brand_pink_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/brand_pink_bg</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Typography -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.Artistico.Display</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Artistico.Headline</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Artistico.Title</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Artistico.TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Artistico.Body</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Artistico.BodyMedium</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Artistico.Label</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Artistico.LabelMedium</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/Shape.Artistico.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.Artistico.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.Artistico.Large</item>

        <!-- Components -->
        <item name="materialButtonStyle">@style/Widget.Artistico.Button</item>
        <item name="textInputStyle">@style/Widget.Artistico.TextInput</item>
    </style>

    <style name="Theme.Artistico.SplashOverride" parent="Theme.Artistico" />
</resources>
