<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.Artistico.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/brand_maroon</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">@color/brand_maroon_soft</item>
        <item name="cornerRadius">@dimen/radius_pill</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Artistico.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_maroon</item>
        <item name="android:textColor">@color/brand_maroon</item>
        <item name="cornerRadius">@dimen/radius_pill</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Artistico.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/brand_maroon</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Artistico.IconButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/text_primary</item>
        <item name="backgroundTint">@color/surface_white</item>
        <item name="iconSize">20dp</item>
    </style>

    <!-- The bottom nav is now a plain LinearLayout (view_bottom_nav.xml);
         M3 BottomNavigationView styles have been removed because the widget's
         internal indicator rendering does not match its layout preview. -->

    <style name="Widget.Artistico.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/divider</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxBackgroundColor">@color/brand_pink_surface</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_pill</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_pill</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_pill</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_pill</item>
        <item name="hintTextColor">@color/text_tertiary</item>
    </style>

    <style name="Widget.Artistico.SearchField" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_search_field</item>
        <item name="android:paddingStart">44dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:imeOptions">actionSearch</item>
        <item name="android:inputType">text</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="Widget.Artistico.CommentField" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_comment_field</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:inputType">textCapSentences|textMultiLine</item>
        <item name="android:maxLines">4</item>
    </style>

    <style name="Widget.Artistico.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.Artistico.Fab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/brand_maroon</item>
        <item name="tint">@color/white</item>
        <item name="borderWidth">0dp</item>
    </style>

    <style name="Widget.Artistico.Fab.Search" parent="Widget.Material3.FloatingActionButton.Secondary">
        <item name="backgroundTint">@color/surface_white</item>
        <item name="tint">@color/text_primary</item>
        <item name="borderWidth">0dp</item>
        <!-- cornerSize > half-width clamps to exactly half = perfect circle on any size -->
        <item name="shapeAppearance">@style/Shape.Artistico.Pill</item>
    </style>
</resources>
