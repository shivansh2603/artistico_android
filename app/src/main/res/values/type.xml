<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="TextAppearance.Artistico.Display" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="fontFamily">sans-serif-black</item>
        <item name="android:textSize">34sp</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineHeight" tools:targetApi="p">40sp</item>
    </style>

    <style name="TextAppearance.Artistico.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="fontFamily">sans-serif-black</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TextAppearance.Artistico.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="fontFamily">sans-serif-black</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.Artistico.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Artistico.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Artistico.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.Artistico.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.Artistico.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Semantic helpers -->
    <style name="Text.Screen.Title" parent="TextAppearance.Artistico.Display">
        <item name="android:textSize">32sp</item>
    </style>

    <style name="Text.Section.Title" parent="TextAppearance.Artistico.Title">
        <item name="android:textSize">20sp</item>
    </style>

    <style name="Text.Timestamp" parent="TextAppearance.Artistico.BodyMedium">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Text.Empty.Prompt" parent="TextAppearance.Artistico.BodyMedium">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Text.Chip.Role" parent="TextAppearance.Artistico.LabelMedium">
        <item name="android:textColor">@color/brand_maroon</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="Text.Stat.Number" parent="TextAppearance.Artistico.Title">
        <item name="android:textSize">18sp</item>
    </style>

    <style name="Text.Stat.Label" parent="TextAppearance.Artistico.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Text.Countdown.Number" parent="TextAppearance.Artistico.Display">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Countdown.Unit" parent="TextAppearance.Artistico.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Text.OnDark.Title" parent="TextAppearance.Artistico.Title">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Text.OnDark.Body" parent="TextAppearance.Artistico.BodyMedium">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Bottom-nav label: equal size for active & inactive removes M3 zoom,
         and 11sp ensures "Challenges" fits in the ~69dp per-item column -->
    <style name="TextAppearance.Artistico.BottomNavLabel" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
</resources>
