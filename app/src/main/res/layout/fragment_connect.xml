<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_pink_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="120dp">

        <!-- Screen title -->
        <TextView
            style="@style/Text.Screen.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="20dp"
            android:text="@string/connect_title" />

        <!-- Search field -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="20dp">

            <EditText
                android:id="@+id/input_search"
                style="@style/Widget.Artistico.SearchField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/search_community_hint" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="36dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_search"
                app:tint="@color/text_tertiary" />
        </FrameLayout>

        <!-- Tab toggle: communities vs chats -->
        <LinearLayout
            android:id="@+id/tab_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/text_primary"
                android:alpha="0.35" />

            <FrameLayout
                android:id="@+id/tab_communities"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/icon_tab_communities"
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:contentDescription="@string/tab_communities"
                    android:src="@drawable/ic_chat_group"
                    app:tint="@color/brand_maroon" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tab_chats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/icon_tab_chats"
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:contentDescription="@string/tab_chats"
                    android:src="@drawable/ic_chat_bubble"
                    app:tint="@color/text_tertiary" />
            </FrameLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/text_primary"
                android:alpha="0.35" />
        </LinearLayout>

        <!-- Content area: recycler OR empty state -->
        <FrameLayout
            android:id="@+id/content_area"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:visibility="gone"
                tools:visibility="gone" />

            <TextView
                android:id="@+id/txt_empty"
                style="@style/Text.Empty.Prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingHorizontal="32dp"
                tools:text="Let's connect, artist!" />
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_new"
        style="@style/Widget.Artistico.Fab"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:contentDescription="@string/cd_new_community"
        app:elevation="8dp"
        app:srcCompat="@drawable/ic_plus" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
