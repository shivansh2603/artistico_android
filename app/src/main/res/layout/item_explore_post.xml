<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_post"
        style="@style/Widget.Artistico.Card"
        android:layout_width="300dp"
        android:layout_height="@dimen/explore_card_height"
        app:cardCornerRadius="@dimen/radius_card">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/img_post"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                tools:src="@drawable/placeholder_image_1" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_like"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:contentDescription="@string/cd_like"
                app:backgroundTint="@color/surface_white"
                app:elevation="2dp"
                app:fabCustomSize="44dp"
                app:maxImageSize="22dp"
                app:srcCompat="@drawable/ic_heart_outline"
                app:tint="@color/like_red" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/img_avatar"
            android:layout_width="@dimen/avatar_sm"
            android:layout_height="@dimen/avatar_sm"
            android:background="@drawable/bg_circle_surface"
            android:clipToOutline="true"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@drawable/placeholder_avatar_artistica" />

        <TextView
            android:id="@+id/txt_author"
            style="@style/TextAppearance.Artistico.TitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Artistica" />

        <ImageView
            android:id="@+id/img_crown"
            android:layout_width="@dimen/icon_sm"
            android:layout_height="@dimen/icon_sm"
            android:layout_marginStart="4dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_crown"
            android:visibility="gone"
            tools:visibility="visible" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/txt_timestamp"
            style="@style/Text.Timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="5mo ago" />
    </LinearLayout>
</LinearLayout>
