<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="10dp">

    <ImageView
        android:id="@+id/img_comment_avatar"
        android:layout_width="@dimen/avatar_sm"
        android:layout_height="@dimen/avatar_sm"
        android:background="@drawable/bg_circle_surface"
        android:clipToOutline="true"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        tools:src="@drawable/placeholder_avatar" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txt_comment_author"
            style="@style/TextAppearance.Artistico.TitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            tools:text="Meera Kapoor" />

        <TextView
            android:id="@+id/txt_comment_text"
            style="@style/TextAppearance.Artistico.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            tools:text="Love the minimal line work!" />

        <TextView
            android:id="@+id/txt_comment_time"
            style="@style/Text.Timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            tools:text="2d ago" />
    </LinearLayout>
</LinearLayout>
