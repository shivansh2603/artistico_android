<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginEnd="12dp"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/img_week_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@drawable/placeholder_week_card" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_week_card_overlay" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_week_number"
                    style="@style/Text.OnDark.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Week 10" />

                <TextView
                    android:id="@+id/txt_week_theme"
                    style="@style/Text.OnDark.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Human Sketch" />
            </LinearLayout>

            <TextView
                android:id="@+id/txt_week_range"
                style="@style/Text.OnDark.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                tools:text="22 - 28 Sep" />
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
