<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/surface_white"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/img_community"
            android:layout_width="@dimen/avatar_lg"
            android:layout_height="@dimen/avatar_lg"
            android:background="@drawable/bg_circle_surface"
            android:clipToOutline="true"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@drawable/placeholder_avatar_artistica" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_community_name"
                style="@style/TextAppearance.Artistico.TitleMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Watercolour Weekly" />

            <TextView
                android:id="@+id/txt_community_tag"
                style="@style/TextAppearance.Artistico.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_tertiary"
                tools:text="#watercolour · 482 members" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
