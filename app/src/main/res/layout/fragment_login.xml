<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_pink_bg"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/txt_title"
        style="@style/Text.Screen.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/login_title"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_subtitle"
        style="@style/TextAppearance.Artistico.TitleMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/login_subtitle"
        android:textColor="@color/text_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_title" />

    <!-- Email -->
    <TextView
        android:id="@+id/label_email"
        style="@style/TextAppearance.Artistico.LabelMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/hint_email"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_subtitle" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_email"
        style="@style/Widget.Artistico.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:hint="@string/hint_email"
        app:boxCornerRadiusBottomEnd="@dimen/radius_field"
        app:boxCornerRadiusBottomStart="@dimen/radius_field"
        app:boxCornerRadiusTopEnd="@dimen/radius_field"
        app:boxCornerRadiusTopStart="@dimen/radius_field"
        app:layout_constraintTop_toBottomOf="@id/label_email"
        app:startIconDrawable="@drawable/ic_email"
        app:startIconTint="@color/text_tertiary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="emailAddress"
            android:inputType="textEmailAddress"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Password -->
    <TextView
        android:id="@+id/label_password"
        style="@style/TextAppearance.Artistico.LabelMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/hint_password"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_email" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_password"
        style="@style/Widget.Artistico.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:hint="@string/hint_password"
        app:boxCornerRadiusBottomEnd="@dimen/radius_field"
        app:boxCornerRadiusBottomStart="@dimen/radius_field"
        app:boxCornerRadiusTopEnd="@dimen/radius_field"
        app:boxCornerRadiusTopStart="@dimen/radius_field"
        app:endIconMode="password_toggle"
        app:endIconTint="@color/text_tertiary"
        app:layout_constraintTop_toBottomOf="@id/label_password"
        app:startIconDrawable="@drawable/ic_lock"
        app:startIconTint="@color/text_tertiary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="password"
            android:inputType="textPassword"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Forgot + Need Help row -->
    <TextView
        android:id="@+id/txt_forgot"
        style="@style/TextAppearance.Artistico.LabelMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackground"
        android:padding="2dp"
        android:text="@string/forgot_password"
        android:textColor="@color/brand_maroon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_password" />

    <TextView
        android:id="@+id/txt_need_help"
        style="@style/TextAppearance.Artistico.LabelMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackground"
        android:padding="2dp"
        android:text="@string/need_help"
        android:textColor="@color/brand_maroon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_password" />

    <!-- Terms checkbox -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/check_terms"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="-4dp"
        android:layout_marginTop="8dp"
        android:minHeight="0dp"
        android:paddingStart="0dp"
        android:text="@string/terms_and_conditions"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        app:buttonTint="@color/brand_maroon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_forgot"
        tools:text="I agree to all the Terms &amp; Conditions.*" />

    <TextView
        android:id="@+id/txt_terms_disclaimer"
        style="@style/TextAppearance.Artistico.BodyMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/terms_disclaimer"
        android:textColor="@color/text_tertiary"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/check_terms" />

    <!-- Log in button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_login"
        style="@style/Widget.Artistico.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/action_login"
        app:cornerRadius="@dimen/radius_field"
        app:layout_constraintTop_toBottomOf="@id/txt_terms_disclaimer" />

    <ProgressBar
        android:id="@+id/progress_login"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="20dp"
        android:indeterminateTint="@color/brand_maroon"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/btn_login"
        app:layout_constraintEnd_toEndOf="@id/btn_login"
        app:layout_constraintTop_toTopOf="@id/btn_login"
        tools:visibility="visible" />

    <!-- Sign up prompt -->
    <TextView
        android:id="@+id/txt_signup_prompt"
        style="@style/TextAppearance.Artistico.BodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="?attr/selectableItemBackground"
        android:padding="4dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_login"
        tools:text="New to Artistico? Sign Up" />

    <!-- or try divider -->
    <View
        android:id="@+id/divider_left"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:background="@color/divider"
        app:layout_constraintBottom_toBottomOf="@id/txt_or_try"
        app:layout_constraintEnd_toStartOf="@id/txt_or_try"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/txt_or_try" />

    <TextView
        android:id="@+id/txt_or_try"
        style="@style/TextAppearance.Artistico.BodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/or_try"
        android:textColor="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_signup_prompt" />

    <View
        android:id="@+id/divider_right"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="24dp"
        android:background="@color/divider"
        app:layout_constraintBottom_toBottomOf="@id/txt_or_try"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/txt_or_try"
        app:layout_constraintTop_toTopOf="@id/txt_or_try" />

    <!-- Continue with Google -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_google"
        style="@style/Widget.Artistico.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/surface_white"
        android:text="@string/continue_with_google"
        android:textColor="@color/text_primary"
        app:cornerRadius="@dimen/radius_field"
        app:icon="@drawable/ic_google"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconSize="22dp"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/txt_or_try"
        app:strokeColor="@color/divider" />
</androidx.constraintlayout.widget.ConstraintLayout>
