<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_pink_bg"
    android:fitsSystemWindows="true"
    tools:context=".ui.main.MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_container"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_root" />

    <!-- Floating pill bottom navigation -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_bar_card"
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="0dp"
        android:layout_height="@dimen/bottom_bar_height"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="@dimen/bottom_bar_margin"
        android:layout_marginEnd="88dp"
        android:layout_marginBottom="@dimen/bottom_bar_margin"
        app:cardBackgroundColor="@color/surface_white"
        app:cardCornerRadius="36dp"
        app:cardElevation="8dp"
        app:layout_anchor="@id/nav_host_container"
        app:layout_anchorGravity="bottom|start">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            style="@style/Widget.Artistico.BottomNav"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            app:elevation="0dp"
            app:menu="@menu/menu_bottom_nav" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Detached search FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_search"
        style="@style/Widget.Artistico.Fab.Search"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="@string/nav_search"
        app:elevation="8dp"
        app:srcCompat="@drawable/ic_search"
        app:tint="@color/text_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
