<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="32dp">

    <!-- Illustration. Weight=1 gives it flexible vertical space; scaleType=fitCenter
         keeps the vector's aspect ratio whatever the slot size. -->
    <ImageView
        android:id="@+id/img_page"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:adjustViewBounds="true"
        android:contentDescription="@string/cd_onboarding_illustration"
        android:scaleType="fitCenter"
        tools:src="@drawable/placeholder_image_1" />

    <TextView
        android:id="@+id/txt_title"
        style="@style/TextAppearance.Artistico.Headline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        tools:text="Global Artist Network" />

    <TextView
        android:id="@+id/txt_description"
        style="@style/TextAppearance.Artistico.BodyMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        tools:text="Forge meaningful connections with talented artists across continents, breaking down creative barriers." />
</LinearLayout>
