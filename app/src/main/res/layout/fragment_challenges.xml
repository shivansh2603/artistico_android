<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_pink_bg"
    android:clipToPadding="false"
    android:paddingBottom="120dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header with info button -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp">

            <TextView
                style="@style/Text.Screen.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:text="@string/challenges_title" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_info"
                style="@style/Widget.Artistico.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end|center_vertical"
                android:contentDescription="@string/cd_challenge_info"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_info"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/text_primary" />
        </FrameLayout>

        <!-- Cover card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_cover"
            style="@style/Widget.Artistico.Card"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface_white">

            <ImageView
                android:id="@+id/img_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:padding="64dp"
                android:scaleType="centerInside"
                tools:src="@drawable/logo_artistico" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Start / End dates row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <TextView
                android:id="@+id/txt_starts"
                style="@style/TextAppearance.Artistico.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:text="Starts- 2 Mar" />

            <TextView
                android:id="@+id/txt_ends"
                style="@style/TextAppearance.Artistico.TitleMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                tools:text="Ends- 8 Mar" />
        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/txt_description"
            style="@style/TextAppearance.Artistico.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp"
            tools:text="An art journal is the same as a written journal…" />

        <!-- Countdown -->
        <TextView
            style="@style/Text.Section.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:text="@string/challenge_ends_in" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp">

            <include
                android:id="@+id/countdown_days"
                layout="@layout/view_countdown_box"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <Space
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <include
                android:id="@+id/countdown_hrs"
                layout="@layout/view_countdown_box"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <Space
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <include
                android:id="@+id/countdown_mins"
                layout="@layout/view_countdown_box"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <Space
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <include
                android:id="@+id/countdown_sec"
                layout="@layout/view_countdown_box"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Add submission button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_submission"
            style="@style/Widget.Artistico.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:text="@string/add_submission" />

        <!-- Previous weeks header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp">

            <TextView
                style="@style/Text.Section.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/previous_weeks" />

            <TextView
                android:id="@+id/txt_see_all"
                style="@style/Widget.Artistico.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/see_all"
                android:textColor="@color/brand_maroon"
                android:padding="8dp" />
        </LinearLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewpager_previous"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            android:overScrollMode="never" />

        <!-- Page indicator -->
        <LinearLayout
            android:id="@+id/page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:orientation="horizontal" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
