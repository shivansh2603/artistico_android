<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_pink_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:backgroundTint="@color/surface_white"
            android:contentDescription="@string/cd_back"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="22dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="22dp"
            app:iconTint="@color/text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_help"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:backgroundTint="@color/surface_white"
            android:contentDescription="@string/cd_help"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="22dp"
            app:icon="@drawable/ic_help_outline"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="22dp"
            app:iconTint="@color/text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txt_title"
            style="@style/Text.Screen.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/signup_title"
            android:textSize="34sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back" />

        <TextView
            android:id="@+id/txt_subtitle"
            style="@style/TextAppearance.Artistico.TitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/signup_subtitle"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_title" />

        <!-- Name -->
        <TextView
            android:id="@+id/label_name"
            style="@style/TextAppearance.Artistico.LabelMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/hint_full_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_subtitle" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_name"
            style="@style/Widget.Artistico.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_full_name"
            app:boxCornerRadiusBottomEnd="@dimen/radius_field"
            app:boxCornerRadiusBottomStart="@dimen/radius_field"
            app:boxCornerRadiusTopEnd="@dimen/radius_field"
            app:boxCornerRadiusTopStart="@dimen/radius_field"
            app:layout_constraintTop_toBottomOf="@id/label_name"
            app:startIconDrawable="@drawable/ic_person_outline"
            app:startIconTint="@color/text_tertiary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="name"
                android:inputType="textPersonName|textCapWords"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email -->
        <TextView
            android:id="@+id/label_email"
            style="@style/TextAppearance.Artistico.LabelMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/hint_email"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/til_name" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_email"
            style="@style/Widget.Artistico.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_email"
            app:boxCornerRadiusBottomEnd="@dimen/radius_field"
            app:boxCornerRadiusBottomStart="@dimen/radius_field"
            app:boxCornerRadiusTopEnd="@dimen/radius_field"
            app:boxCornerRadiusTopStart="@dimen/radius_field"
            app:layout_constraintTop_toBottomOf="@id/label_email"
            app:startIconDrawable="@drawable/ic_email"
            app:startIconTint="@color/text_tertiary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="emailAddress"
                android:inputType="textEmailAddress"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password -->
        <TextView
            android:id="@+id/label_password"
            style="@style/TextAppearance.Artistico.LabelMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/hint_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/til_email" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_password"
            style="@style/Widget.Artistico.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_password"
            app:boxCornerRadiusBottomEnd="@dimen/radius_field"
            app:boxCornerRadiusBottomStart="@dimen/radius_field"
            app:boxCornerRadiusTopEnd="@dimen/radius_field"
            app:boxCornerRadiusTopStart="@dimen/radius_field"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_tertiary"
            app:layout_constraintTop_toBottomOf="@id/label_password"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="@color/text_tertiary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="newPassword"
                android:inputType="textPassword"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Confirm Password -->
        <TextView
            android:id="@+id/label_confirm"
            style="@style/TextAppearance.Artistico.LabelMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/hint_confirm_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/til_password" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_confirm"
            style="@style/Widget.Artistico.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_confirm_password"
            app:boxCornerRadiusBottomEnd="@dimen/radius_field"
            app:boxCornerRadiusBottomStart="@dimen/radius_field"
            app:boxCornerRadiusTopEnd="@dimen/radius_field"
            app:boxCornerRadiusTopStart="@dimen/radius_field"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_tertiary"
            app:layout_constraintTop_toBottomOf="@id/label_confirm"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="@color/text_tertiary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_confirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="newPassword"
                android:inputType="textPassword"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Terms -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/check_terms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/terms_and_conditions"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:buttonTint="@color/brand_maroon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/til_confirm"
            tools:text="I agree to all the Terms &amp; Conditions.*" />

        <TextView
            android:id="@+id/txt_terms_disclaimer"
            style="@style/TextAppearance.Artistico.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/terms_disclaimer"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/check_terms" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sign_up"
            style="@style/Widget.Artistico.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/action_sign_up"
            app:cornerRadius="@dimen/radius_field"
            app:layout_constraintTop_toBottomOf="@id/txt_terms_disclaimer" />

        <ProgressBar
            android:id="@+id/progress_sign_up"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="20dp"
            android:indeterminateTint="@color/brand_maroon"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/btn_sign_up"
            app:layout_constraintEnd_toEndOf="@id/btn_sign_up"
            app:layout_constraintTop_toTopOf="@id/btn_sign_up"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/txt_login_prompt"
            style="@style/TextAppearance.Artistico.BodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="?attr/selectableItemBackground"
            android:padding="6dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_sign_up"
            tools:text="Already have an account? Log in" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
