<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_pink_bg">

    <!-- Top app bar: back / title / overflow -->
    <FrameLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Artistico.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start|center_vertical"
            android:contentDescription="@string/cd_back"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/text_primary" />

        <TextView
            style="@style/TextAppearance.Artistico.TitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/post_details_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_overflow"
            style="@style/Widget.Artistico.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|center_vertical"
            android:contentDescription="@string/cd_more"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_more_horiz"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/text_primary" />
    </FrameLayout>

    <!-- Scrollable body -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/comment_composer"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Author header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:id="@+id/img_author"
                    android:layout_width="@dimen/avatar_md"
                    android:layout_height="@dimen/avatar_md"
                    android:background="@drawable/bg_circle_surface"
                    android:clipToOutline="true"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/placeholder_avatar" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txt_author_name"
                        style="@style/TextAppearance.Artistico.TitleMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Pragya Singh" />

                    <TextView
                        android:id="@+id/txt_author_timestamp"
                        style="@style/Text.Timestamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="5mo ago" />
                </LinearLayout>
            </LinearLayout>

            <!-- Full-bleed image -->
            <ImageView
                android:id="@+id/img_post"
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:background="@color/surface_white"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                tools:src="@drawable/placeholder_image_1" />

            <!-- Like (right-aligned) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btn_like"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end"
                    android:contentDescription="@string/cd_like"
                    app:backgroundTint="@color/surface_white"
                    app:elevation="2dp"
                    app:srcCompat="@drawable/ic_heart_outline"
                    app:tint="@color/like_red" />
            </FrameLayout>

            <!-- Description -->
            <TextView
                style="@style/Text.Section.Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:text="@string/description" />

            <TextView
                android:id="@+id/txt_description"
                style="@style/TextAppearance.Artistico.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingBottom="16dp"
                tools:text="#Photography" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="20dp"
                android:background="@color/divider" />

            <!-- Comments section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp">

                <TextView
                    style="@style/Text.Section.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/comments" />

                <TextView
                    android:id="@+id/txt_comments_empty"
                    style="@style/TextAppearance.Artistico.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="6dp"
                    android:textColor="@color/text_tertiary"
                    tools:text="Be the first one to comment on Pragya Singh's post"
                    tools:visibility="visible" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_comments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_comment"
                    tools:visibility="gone" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom comment composer -->
    <LinearLayout
        android:id="@+id/comment_composer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_pink_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/img_me_avatar"
            android:layout_width="@dimen/avatar_sm"
            android:layout_height="@dimen/avatar_sm"
            android:background="@drawable/bg_circle_surface"
            android:clipToOutline="true"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_avatar" />

        <EditText
            android:id="@+id/input_comment"
            style="@style/Widget.Artistico.CommentField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_weight="1"
            android:hint="@string/write_a_comment" />

        <ImageView
            android:id="@+id/btn_send"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_send_comment"
            android:padding="8dp"
            android:src="@drawable/ic_send"
            app:tint="@color/text_primary" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
